# Runtime environment (example)

# Required API keys (comma-separated secret names)
ATS_REQUIRED_SECRETS=BINANCE_API_KEY,BINANCE_API_SECRET,OPENAI_API_KEY

# Startup health control
ATS_ENFORCE_STARTUP_HEALTH=true
ATS_ENFORCE_STALE_DATA_ON_STARTUP=true
ATS_ENFORCE_STALE_DATA_ON_REQUEST=true

# Stale data guard
ATS_MARKET_HEARTBEAT_PATH=/home/deploy/ats/var/run/market_data_heartbeat.json
ATS_STALE_DATA_MAX_SECONDS=120

# Core paths
ATS_CONSTITUTION_PATH=/home/deploy/ats/infra/config/constitution.v1.json
ATS_EVENT_LOG_DIR=/home/deploy/ats/var/log/events
